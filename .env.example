# ─── Firebase Client (público — prefixo NEXT_PUBLIC_) ───────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server-side apenas) ────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── AbacatePay ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

ABACATEPAY_API_KEY=
ABACATEPAY_PUBLIC_KEY=

# ─── Resend (email transacional + caixa de mensagens) ───────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@mikma.com.br
# Endereço de contato usado para respostas enviadas pelo painel e como
# Reply-To. Precisa estar verificado no Resend junto com o domínio.
EMAIL_CONTATO_ADDRESS=contato@mikma.com.br
# Gerado no dashboard do Resend ao criar o endpoint de webhook (Receiving
# Emails → Add webhook). Usado para verificar a assinatura do /api/email/inbound.
RESEND_WEBHOOK_SECRET=

# ─── reCAPTCHA v3 ────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Uber Direct ─────────────────────────────────────────────────────────────
# Obter em: developer.uber.com → seu app → Credentials / Webhooks
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
UBER_DIRECT_CUSTOMER_ID=
UBER_DIRECT_WEBHOOK_SECRET=
# UBER_DIRECT_SANDBOX=true  ← descomente só para testes

# ─── Melhor Envio ────────────────────────────────────────────────────────────
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=true

# ─── Correios API REST v2 (fallback se não tiver Melhor Envio) ───────────────
# Obter em: https://cws.correios.com.br — cadastro de cartão postagem
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_CODIGO_ACESSO=

# ─── Total Express ────────────────────────────────────────────────────────────
# Solicitar credenciais em: https://totalexpress.com.br/seja-parceiro
TOTAL_EXPRESS_TOKEN=
TOTAL_EXPRESS_CLIENT_CODE=

# ─── Disk Tenha — tabela de preços por faixa de distância (centavos) ────────
# Configure de acordo com o contrato com o Disk Tenha local
DISK_TENHA_PRICE_3KM=600
DISK_TENHA_PRICE_7KM=900
DISK_TENHA_PRICE_12KM=1300
DISK_TENHA_PRICE_20KM=1800

# ─── Algolia ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# ─── Upstash Redis (rate limiting) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://mikmalencois.com.br
NEXT_PUBLIC_STORE_CEP=
NEXT_PUBLIC_STORE_ADDRESS=
UBER_DIRECT_RADIUS_KM=10
