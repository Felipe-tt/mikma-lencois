# eslint-config-next ainda declara peerDependency eslint ^7||^8||^9 e não
# inclui eslint 10 (mesmo funcionando bem na prática, já que usamos flat
# config via FlatCompat). Sem isso, "npm ci" no CI falha com ERESOLVE
# assim que o eslint for atualizado para a v10. Remover esta linha quando
# eslint-config-next publicar suporte oficial a eslint 10 no peerDependencies.
legacy-peer-deps=true
