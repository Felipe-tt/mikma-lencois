rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }
    function isSellerOrAdmin() {
      return hasRole('seller') || hasRole('admin');
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSelf(uid) || hasRole('admin');
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    // ── Products (leitura pública, escrita apenas vendedor/admin) ───────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isSellerOrAdmin();
    }

    // ── Inventory ────────────────────────────────────────────────────────────
    match /inventory/{sku} {
      allow read: if true;
      allow write: if isSellerOrAdmin();
    }

    // ── Carts ────────────────────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isSelf(userId);
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Comprador lê somente os próprios pedidos
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isSellerOrAdmin()
      );
      // Criação via API route (Admin SDK) — cliente nunca escreve direto
      allow create: if false;
      // Atualização de status só por vendedor/admin (via Admin SDK de preferência)
      allow update: if isSellerOrAdmin();
      allow delete: if hasRole('admin');
    }

    // ── Coupons ──────────────────────────────────────────────────────────────
    match /coupons/{code} {
      allow read: if isAuth();
      allow write: if isSellerOrAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isSellerOrAdmin();
    }

    // ── Stock Alerts ─────────────────────────────────────────────────────────
    match /stockAlerts/{sku} {
      allow read, write: if isSellerOrAdmin();
    }

    // ── Notifications (subcoleção por usuário) ────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read: if isSelf(userId) || isSellerOrAdmin();
      allow write: if isSellerOrAdmin();
    }

    // ── Tudo mais: negar por padrão ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
