rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }
    function isSellerOrAdmin() {
      return hasRole('seller') || hasRole('admin');
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Seller/admin precisam ler dados do cliente (nome, telefone, endereço)
      // ao visualizar o detalhe de um pedido no painel.
      allow read: if isSelf(uid) || isSellerOrAdmin();
      allow create: if isSelf(uid);
      // isSelf só pode atualizar o próprio doc SE o campo role não mudar
      // (senão um comprador poderia se autopromover a seller/admin no
      // Firestore — o custom claim do token continuaria 'buyer', mas
      // qualquer código que ler o role daqui em vez do claim seria
      // enganado). Só admin pode alterar o role de alguém.
      // .get(key, default) em vez de acesso direto por ponto: a maioria
      // dos compradores nunca teve campo "role" no Firestore (só existe
      // via custom claim do token) — acesso direto a um campo ausente
      // lança erro de avaliação, e regra com erro = negada por padrão.
      // Isso quebrava QUALQUER usuário sem o campo salvando o próprio
      // perfil (ex: endereço no checkout) com "Missing or insufficient
      // permissions", mesmo sendo o dono do documento.
      allow update: if (isSelf(uid) && request.resource.data.get('role', null) == resource.data.get('role', null))
        || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    // ── Products (leitura pública, escrita apenas vendedor/admin) ───────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isSellerOrAdmin();
    }

    // ── Inventory ────────────────────────────────────────────────────────────
    match /inventory/{sku} {
      allow read: if true;
      // 'reserved' é gerido só pelo fluxo de pedidos (Admin SDK, que ignora
      // estas regras) — o painel de estoque nunca deve poder mexer nele.
      // 'history' só pode crescer (arrayUnion), nunca ser reduzido/apagado.
      allow update: if isSellerOrAdmin()
        && request.resource.data.quantity is number
        && request.resource.data.lowStockThreshold is number
        && request.resource.data.lowStockThreshold >= 0
        && request.resource.data.reserved == resource.data.reserved
        && request.resource.data.history.size() >= resource.data.history.size();
      allow create: if isSellerOrAdmin();
      allow delete: if false;
    }

    // ── Carts ────────────────────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isSelf(userId);
    }

    // ── Wishlists (favoritos) ───────────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if isSelf(userId);
    }

    // ── Reviews ──────────────────────────────────────────────────────────────
    // Leitura pública (mostrado na página do produto). Criação só via API
    // route (Admin SDK) — precisa validar que o pedido é do usuário, está
    // 'delivered' e contém o produto, o que não dá pra expressar com
    // segurança só em regra do Firestore. Edição/exclusão: só admin
    // (moderação de conteúdo abusivo).
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if hasRole('admin');
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Comprador lê somente os próprios pedidos
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isSellerOrAdmin()
      );
      // Criação via API route (Admin SDK) — cliente nunca escreve direto
      allow create: if false;
      // Atualização de status só por vendedor/admin (via Admin SDK de preferência)
      allow update: if isSellerOrAdmin();
      // Delete: admin sempre; seller só pode deletar pedidos cancelados
      allow delete: if hasRole('admin') || (
        hasRole('seller') && resource.data.status == 'cancelled'
      );
    }

    // ── Coupons ──────────────────────────────────────────────────────────────
    match /coupons/{code} {
      allow read: if isAuth();
      allow write: if isSellerOrAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isSellerOrAdmin();
    }

    // ── Stock Alerts ─────────────────────────────────────────────────────────
    match /stockAlerts/{sku} {
      allow read, write: if isSellerOrAdmin();
    }

    // ── Notifications (subcoleção por usuário) ────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read: if isSelf(userId) || isSellerOrAdmin();
      allow write: if isSellerOrAdmin();
    }

    // ── Push tokens (FCM) — só o backend (Admin SDK) acessa; nunca o client ──
    // Tokens são vinculados a seller/admin pelo endpoint /api/painel/push-token
    // (que valida a role via verifyAuth). Não expor leitura/escrita direta:
    // um vendor não deve ver ou apagar o token de outro vendor pelo client.
    match /pushTokens/{tokenId} {
      allow read, write: if false;
    }

    // ── Maintenance — leitura pública (status), escrita só admin/seller ───────
    match /maintenance/{doc} {
      allow read: if true;
      allow write: if isSellerOrAdmin();
    }
    match /maintenance_queue/{doc} {
      allow read: if true;        // middleware precisa checar
      // O middleware roda sem autenticação (Edge Runtime) e precisa
      // conseguir registrar visitantes na fila — só permite CRIAR um
      // documento novo com released=false (não dá pra um visitante
      // anônimo se auto-liberar nem sobrescrever um registro existente).
      allow create: if request.resource.data.released == false;
      // Liberar (mudar released pra true) ou apagar continua exigindo
      // seller/admin autenticado.
      allow update, delete: if isSellerOrAdmin();
    }

    // ── Conversas de e-mail (caixa de mensagens do painel) ──────────────────
    match /conversations/{convId} {
      allow read: if isSellerOrAdmin();
      // Criação/escrita normal só via Admin SDK (webhook inbound, rota de
      // envio). O client só pode marcar como lida (unread: false) — não
      // pode alterar nenhum outro campo nem criar/deletar a conversa.
      allow create, delete: if false;
      allow update: if isSellerOrAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unread']);

      match /messages/{messageId} {
        allow read: if isSellerOrAdmin();
        // Escrita só via Admin SDK (webhook inbound, rota de envio).
        allow write: if false;
      }
    }

    // ── WhatsApp catalog import ──────────────────────────────────────────────
    // Sessão do WhatsApp (credenciais Baileys) — equivale a estar logado na
    // conta. Acesso SOMENTE pelo Admin SDK (que ignora estas regras). Client
    // nunca lê nem escreve, nem seller/admin.
    match /whatsappAuth/{doc} {
      allow read, write: if false;
    }
    match /whatsappAuthKeys/{doc} {
      allow read, write: if false;
    }
    // Status da conexão + QR code atual — não é sensível por si só (QR
    // expira em segundos), seller/admin pode ler em tempo real pra exibir
    // na tela de importação. Escrita só pelo Admin SDK.
    match /whatsappCatalogStatus/{doc} {
      allow read: if isSellerOrAdmin();
      allow write: if false;
    }

    // ── Equipe (quem tem acesso ao painel) ───────────────────────────────────
    // Só existe pra exibição na tela de configurações. A autorização de
    // verdade nunca vem daqui — sempre do custom claim do token (ver
    // /api/painel/team). Acesso exclusivo pelo Admin SDK, direto do client
    // (mesmo admin) não lê nem escreve, pra não abrir brecha de alguém
    // editar a própria role aqui direto.
    match /team/{uid} {
      allow read, write: if false;
    }

    // ── Tudo mais: negar por padrão ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
